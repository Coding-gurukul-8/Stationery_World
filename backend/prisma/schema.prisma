// =====================================================
// STATIONERY WORLD — COMPLETE PRISMA SCHEMA
// Version: 3.0.0
// Changes from v2.1.0:
//   - User: added lastSeenAt (sliding JWT / 10-day auto-logout)
//   - ProductVariantGroup: new model linking similar products (colors, sizes, types)
//   - AdminPaymentSettings: UPI ID + QR code per admin
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// USERS & AUTHENTICATION
// =====================================================

model User {
  id           Int     @id @default(autoincrement())
  name         String
  email        String  @unique
  phone        String? @unique

  // Profile & Address Fields
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  photoUrl     String?

  passwordHash String
  role         Role    @default(CUSTOMER)
  isActive     Boolean @default(true)

  // ── Sliding-session tracking ──────────────────────────────────────────────
  // Updated on every authenticated request via authMiddleware.
  // If now - lastSeenAt > 10 days the token is treated as expired even if the
  // JWT signature is still valid — user must log in again.
  lastSeenAt   DateTime @default(now())

  // Relations
  orders               Order[]               @relation("UserOrders")
  adminOrders          Order[]               @relation("AdminOrders")
  placedOrders         Order[]               @relation("PlacedByOrders")
  wishlists            Wishlist[]
  payments             Payment[]
  bargainAttempts      BargainAttempt[]
  cartItems            Cart[]
  inventoryLogs        InventoryLog[]
  orderAudits          OrderAudit[]
  profitLedger         ProfitLedger[]
  otps                 OTP[]
  createdProducts      Product[]             @relation("ProductCreatedBy")
  productNotifications ProductNotification[]
  bargainPermissions   BargainPermission[]   @relation("UserBargainPermissions")
  grantedBargains      BargainPermission[]   @relation("GrantedBargains")
  bargainRequests      BargainRequest[]      @relation("UserBargainRequests")
  bargainReviewedRequests BargainRequest[]   @relation("BargainRequestReview")
  paymentSettings      AdminPaymentSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// =====================================================
// OTP FOR PASSWORD RESET
// =====================================================

model OTP {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp")
  @@index([email])
  @@index([otp])
  @@index([userId])
}

// =====================================================
// PRODUCTS & CATALOG
// =====================================================

model Product {
  id               Int      @id @default(autoincrement())
  uid              String?  @unique @default(uuid())
  name             String
  description      String?
  keywords         String[] @default([])
  category         Category
  subCategory      String

  // Pricing
  costPrice        Float
  baseSellingPrice Float
  bargainable      Boolean @default(true)

  // Stock Management
  totalStock        Int     @default(0)
  totalSold         Int     @default(0)
  lowStockThreshold Int     @default(10)
  isActive          Boolean @default(true)

  // Creator tracking
  createdBy   User? @relation("ProductCreatedBy", fields: [createdById], references: [id])
  createdById Int?

  // Variant group link
  variantGroup   ProductVariantGroup? @relation(fields: [variantGroupId], references: [id])
  variantGroupId Int?

  // Relations
  images             ProductImage[]
  inventoryLogs      InventoryLog[]
  bargainConfig      BargainConfig?
  bargainPermissions BargainPermission[]  @relation("ProductBargainPermissions")
  bargainRequests    BargainRequest[]     @relation("ProductBargainRequests")
  orderItems         OrderItem[]
  wishlists          Wishlist[]
  bargainAttempts    BargainAttempt[]
  cartItems          Cart[]
  notifications      ProductNotification[]
  bulkDiscounts      BulkDiscount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
  @@index([name])
  @@index([uid])
  @@index([category])
  @@index([variantGroupId])
}

// =====================================================
// PRODUCT VARIANT GROUPS
// Links similar products that differ only by color/size/type/style.
//
// Examples:
//   Linc Pentonic pens → group "Linc Pentonic", type COLOR
//     - Blue variant  (Product id=1)
//     - Black variant (Product id=2)
//     - Red variant   (Product id=3)
//
//   Classmate Notebook → group "Classmate NB 160pg", type SIZE
//     - Plain 160pg   (Product id=4)
//     - Ruled 160pg   (Product id=5)
//     - Plain 240pg   (Product id=6)
//
//   Face-changing Keychain → group "Face Keychain", type STYLE
//     - Shinchan       (Product id=7)
//     - Doraemon       (Product id=8)
//     - Capybara       (Product id=9)
// =====================================================

model ProductVariantGroup {
  id          Int                 @id @default(autoincrement())
  name        String              // Display name for the group
  variantType VariantType         // COLOR | SIZE | TYPE | STYLE
  description String?

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_variant_groups")
  @@index([variantType])
}

enum VariantType {
  COLOR   // e.g. Blue/Black/Red pen
  SIZE    // e.g. 160pg/240pg/320pg notebook
  TYPE    // e.g. Plain/Ruled/Single-rule pages
  STYLE   // e.g. Shinchan/Doraemon/Capybara keychain
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  position  Int     @default(0)   // explicit ordering — 0 = primary slot

  createdAt DateTime @default(now())

  @@map("product_images")
  @@index([productId, position])
}

model InventoryLog {
  id        Int             @id @default(autoincrement())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  action    InventoryAction
  quantity  Int
  admin     User?           @relation(fields: [adminId], references: [id])
  adminId   Int?
  note      String?
  createdAt DateTime        @default(now())

  @@map("inventory_logs")
  @@index([productId])
}

enum InventoryAction {
  ADD
  RESTOCK
  SALE
  ADJUST
  ORDER_DEDUCTION
  ORDER_RESTORATION
}

enum Category {
  STATIONERY
  BOOKS
  TOYS
}

// =====================================================
// BARGAINING SYSTEM
// =====================================================

model BargainConfig {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int     @unique

  tier1Price  Float
  tier2Price  Float
  tier3Price  Float
  maxAttempts Int     @default(3)
  isActive    Boolean @default(true)

  bargainPercentageLimit        Float?
  bargainAmountLimit            Float?
  minimumCartValueForBargain    Float?
  minimumCustomerOrdersRequired Int?   @default(0)
  bargainExpiryDate             DateTime?
  bargainStockLimit             Int?
  bargainStockUsed              Int       @default(0)
  cooldownMinutes               Int       @default(30)
  lockDurationMinutes           Int       @default(30)
  requiresLogin                 Boolean   @default(true)
  allowCouponCombination        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bargain_configs")
  @@index([productId, isActive])
  @@index([bargainExpiryDate])
}

model BargainPermission {
  id          Int      @id @default(autoincrement())
  user        User     @relation("UserBargainPermissions", fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  product     Product  @relation("ProductBargainPermissions", fields: [productId], references: [id], onDelete: Cascade)
  productId   Int
  grantedBy   User?    @relation("GrantedBargains", fields: [grantedById], references: [id])
  grantedById Int?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("bargain_permissions")
}

model BargainRequest {
  id          Int      @id @default(autoincrement())
  user        User     @relation("UserBargainRequests", fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  product     Product  @relation("ProductBargainRequests", fields: [productId], references: [id], onDelete: Cascade)
  productId   Int

  status      BargainRequestStatus  @default(PENDING)
  note        String?

  reviewedBy   User?    @relation("BargainRequestReview", fields: [reviewedById], references: [id])
  reviewedById Int?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@map("bargain_requests")
}

enum BargainRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model BargainAttempt {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId   Int?

  attemptNumber   Int
  offeredPrice    Float
  accepted        Boolean @default(false)

  acceptedTier    Int?
  finalPrice      Float?
  offerLockExpiry DateTime?
  rejectionReason String?
  isAbused        Boolean @default(false)
  ipAddress       String?
  userAgent       String?
  addedToCart     Boolean @default(false)
  cartAddedAt     DateTime?
  purchasedAt     DateTime?

  createdAt     DateTime @default(now())
  lastAttemptAt DateTime @default(now())

  @@unique([userId, productId, orderId])
  @@index([userId, productId])
  @@index([userId, isAbused])
  @@index([productId, accepted])
  @@index([offerLockExpiry])
  @@map("bargain_attempts")
}

model BulkDiscount {
  id        Int          @id @default(autoincrement())
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  minQty    Int
  discount  Float
  unit      DiscountUnit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("bulk_discounts")
}

enum DiscountUnit {
  RUPEES
  PERCENT
}

// =====================================================
// CART SYSTEM
// =====================================================

model Cart {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  quantity  Int     @default(1)

  priceAtAdd     Float
  bargainApplied Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart")
}

// =====================================================
// WISHLIST
// =====================================================

model Wishlist {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  addedAt   DateTime @default(now())
  note      String?

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist")
}

// =====================================================
// ORDERS & TRANSACTIONS
// =====================================================

model Order {
  id  Int    @id @default(autoincrement())
  uid String @unique @default(uuid())

  user       User? @relation("UserOrders",   fields: [userId],     references: [id])
  userId     Int?
  placedBy   User? @relation("PlacedByOrders", fields: [placedById], references: [id])
  placedById Int?
  admin      User? @relation("AdminOrders",  fields: [adminId],    references: [id])
  adminId    Int?

  type   OrderType   @default(CUSTOMER)
  status OrderStatus @default(PENDING)

  isPaid        Boolean        @default(false)
  paidAt        DateTime?
  paymentMethod PaymentMethod?

  refundIssued Boolean   @default(false)
  refundedAt   DateTime?
  refundAmount Float?

  recipientName  String
  recipientPhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  note           String?

  totalAmount Float @default(0)
  totalSp     Float @default(0)
  totalCp     Float @default(0)

  items           OrderItem[]
  payment         Payment?
  bargainAttempts BargainAttempt[]
  audits          OrderAudit[]
  profitLedgers   ProfitLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
  @@index([userId])
  @@index([adminId])
  @@index([placedById])
  @@index([status])
  @@index([isPaid])
  @@index([createdAt])
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int

  product   Product? @relation(fields: [productId], references: [id])
  productId Int?

  productName  String
  productPhoto String?

  quantity Int

  cp           Float
  sp           Float
  subtotalSp   Float
  subtotalCp   Float
  priceAtOrder Float
  bargainApplied Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
  @@index([orderId])
}

model OrderAudit {
  id         Int         @id @default(autoincrement())
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    Int
  admin      User?       @relation(fields: [adminId], references: [id])
  adminId    Int?
  fromStatus OrderStatus
  toStatus   OrderStatus
  note       String?
  createdAt  DateTime    @default(now())

  @@map("order_audits")
  @@index([orderId])
}

model ProfitLedger {
  id      Int    @id @default(autoincrement())
  admin   User   @relation(fields: [adminId], references: [id])
  adminId Int
  order   Order? @relation(fields: [orderId], references: [id])
  orderId Int?
  amount  Float
  note    String?

  createdAt DateTime @default(now())

  @@map("profit_ledger")
  @@index([adminId])
}

enum OrderType {
  SELF
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
}

// =====================================================
// PAYMENTS
// =====================================================

model Payment {
  id            Int           @id @default(autoincrement())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       Int           @unique
  user          User          @relation(fields: [userId], references: [id])
  userId        Int
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
  @@index([userId])
  @@index([status])
}

// ── UPI / QR payment settings per admin ──────────────────────────────────────
// Each admin (shop keeper) sets their UPI ID and optionally uploads a QR code.
// Customers see this when paying for orders belonging to that admin's products.

model AdminPaymentSettings {
  id        Int    @id @default(autoincrement())
  admin     User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   Int    @unique

  upiId     String?   // e.g. priyanshu@upi
  qrCodeUrl String?   // Supabase Storage public URL for the QR image
  displayName String? // Friendly name shown to customers, e.g. "Stationery World"
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_payment_settings")
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  UPI
  CASH
  NET_BANKING
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id      Int              @id @default(autoincrement())
  userId  Int?
  type    NotificationType
  message String
  isRead  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  LOW_STOCK
  ORDER_UPDATE
  PAYMENT_STATUS
  SYSTEM_ALERT
}

model ProductNotification {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String
  notified  Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@map("product_notifications")
  @@index([productId])
  @@index([userId])
  @@index([notified])
}
